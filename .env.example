# ============================================
# Environment Configuration
# ============================================

# Node Environment
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================

DB_HOST=postgres
DB_PORT=5432
DB_USER=quickcart
DB_PASSWORD=quickcart123
DB_NAME=quickcart_db

# PostgreSQL Direct Connection URL
DATABASE_URL=postgresql://quickcart:quickcart123@postgres:5432/quickcart_db

# ============================================
# Redis Configuration
# ============================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT & Authentication
# ============================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRATION=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production-67890
REFRESH_TOKEN_EXPIRATION=7d
BCRYPT_ROUNDS=10

# ============================================
# RabbitMQ Configuration
# ============================================

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ============================================
# MinIO (S3-Compatible Object Storage)
# ============================================

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=quickcart-images
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# ============================================
# Service URLs (Internal Docker Network)
# ============================================

AUTH_SERVICE_URL=http://auth-service:3001
PRODUCT_SERVICE_URL=http://product-service:3002
CART_SERVICE_URL=http://cart-service:3003
ORDER_SERVICE_URL=http://order-service:3004
NOTIFICATION_SERVICE_URL=http://notification-service:3005
DELIVERY_SERVICE_URL=http://delivery-service:3006

# ============================================
# Frontend Configuration
# ============================================

VITE_API_BASE_URL=http://localhost
VITE_SOCKET_IO_URL=http://localhost:3006

# ============================================
# Email Configuration (Optional)
# ============================================

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@quickcart.com

# ============================================
# Service Ports
# ============================================

AUTH_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
CART_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
DELIVERY_SERVICE_PORT=3006
FRONTEND_PORT=3000
NGINX_PORT=80

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================
# CORS Configuration
# ============================================

CORS_ORIGIN=http://localhost:3000,http://localhost:80

# ============================================
# Rate Limiting (Optional)
# ============================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Timeout Configuration
# ============================================

REQUEST_TIMEOUT_MS=30000
DATABASE_TIMEOUT_MS=10000

# ============================================
# Feature Flags
# ============================================

ENABLE_SOCKET_IO=true
ENABLE_CACHING=true
ENABLE_RATE_LIMITING=false
ENABLE_REQUEST_LOGGING=true
