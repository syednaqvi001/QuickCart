# Environment
NODE_ENV=development

# Server
PORT=3001

# Database
DATABASE_URL=postgresql://quickcart:quickcart123@postgres:5432/quickcart_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRATION=15m

# Refresh Token
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXPIRATION=7d

# Password Hashing
BCRYPT_ROUNDS=10

# Logging
LOG_LEVEL=debug
